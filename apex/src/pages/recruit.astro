---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const projects = [
  {
    name: 'Git講座',
    description: '共同開発のチュートリアル。まずはここから！',
    tags: ['Git', 'GitHub'],
    color: 'var(--green)',
    lightColor: 'var(--light-green)',
    url: 'https://gitnote.rubydog.jp/',
    urlLabel: 'Git講座を体験してみる',
  },
  {
    name: 'Comet',
    subtitle: 'コメット',
    description: '10 分で自分のサイトを公開できる！ Flutter で作られた静的サイトジェネレーター。',
    tags: ['Flutter'],
    color: 'var(--blue)',
    lightColor: 'var(--light-blue)',
    url: 'https://comet.rubydog.jp/',
    urlLabel: 'Cometを使ってみる',
    extra: { label: '共同開発スタッフの皆様へ', url: 'https://comet.rubydog.jp/docs-jp/oss-contributing/' }
  },
  {
    name: 'AppFlowy',
    subtitle: 'アップフロウィー',
    description: 'オープンソース版の Notion として注目されています。推しの OSS として参加をサポート中。',
    tags: ['Flutter', 'Rust', 'Tauri'],
    color: '#9B59B6',
    lightColor: 'rgba(155,89,182,0.1)',
    url: 'https://appflowy.io/',
    urlLabel: 'AppFlowy公式サイトへ',
  },
  {
    name: 'マグネタリウム',
    description: '宇宙磁石とプラネタリウムのゲーム。',
    tags: [],
    color: 'var(--yellow)',
    lightColor: 'var(--light-yellow)',
    url: null,
    urlLabel: '準備中',
  }
];
---

<PageLayout title="参加" description="共同開発プロジェクトへの参加をお待ちしています">
  <PageHeader title="コミュニティ参加" description="共同開発プロジェクトへの参加をお待ちしています" accentColor="red" />

  <div class="recruit-container">
    <!-- Intro -->
    <div class="intro-card" data-aos="fade-up">
      <p>
        どなたでも気軽に参加できます。気になったプロジェクトがあれば是非ご検討ください。<br />
        どれもゆるいライセンスですので、やがては自分のものとして派生プロジェクトを作り直すことも自由です。
      </p>
    </div>

    <!-- Projects -->
    <div class="projects-list">
      {projects.map((p, i) => (
        <article class="project-card" data-aos="fade-up" data-aos-delay={i * 80}>
          <div class="project-accent" style={`background: ${p.color}`}></div>
          <div class="project-body">
            <h2>
              {p.name}
              {p.subtitle && <span class="project-sub">{p.subtitle}</span>}
            </h2>
            <p class="project-desc">{p.description}</p>
            {p.tags.length > 0 && (
              <div class="tag-row">
                {p.tags.map(tag => (
                  <span class="tag" style={`background: ${p.lightColor}; color: ${p.color}`}>{tag}</span>
                ))}
              </div>
            )}
            <div class="project-actions">
              {p.url ? (
                <a href={p.url} target="_blank" rel="noopener noreferrer" class="action-btn" style={`background: ${p.color}`} data-magnetic>
                  {p.urlLabel}
                </a>
              ) : (
                <span class="action-btn disabled">{p.urlLabel}</span>
              )}
              {p.extra && (
                <a href={p.extra.url} target="_blank" rel="noopener noreferrer" class="action-btn secondary" data-magnetic>
                  {p.extra.label}
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Recruitment Notice -->
    <div class="notice-card" data-aos="fade-up">
      <div class="notice-bar"></div>
      <div class="notice-body">
        <h3>採用情報</h3>
        <p>
          弊コミュニティにご関心いただき、誠にありがとうございます。<br />
          現在、有給でのスタッフの求人募集は行っておりません。募集の際は当ページにてご案内いたします。
        </p>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .recruit-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .intro-card {
    background: rgba(0,0,0,0.02);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
  }
  .intro-card p {
    color: #555;
    line-height: 1.8;
    margin: 0;
    font-size: 0.95rem;
  }

  /* Project Cards */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .project-card {
    display: flex;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.04);
    transition: all 0.25s;
  }
  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.1);
  }

  .project-accent {
    width: 5px;
    flex-shrink: 0;
  }

  .project-body {
    padding: 1.5rem 2rem;
    flex: 1;
  }

  .project-body h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .project-sub {
    font-size: 0.85rem;
    color: #999;
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .project-desc {
    color: #555;
    line-height: 1.7;
    margin: 0 0 1rem;
    font-size: 0.95rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .tag {
    padding: 0.25rem 0.7rem;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: 'Courier New', monospace;
  }

  .project-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .action-btn {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    color: white;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .action-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .action-btn.secondary {
    background: #555;
  }
  .action-btn.disabled {
    background: #ccc;
    cursor: default;
    box-shadow: none;
  }
  .action-btn.disabled:hover {
    transform: none;
    box-shadow: none;
  }

  /* Notice */
  .notice-card {
    display: flex;
    background: rgba(0,0,0,0.02);
    border-radius: 16px;
    overflow: hidden;
  }

  .notice-bar {
    width: 5px;
    background: linear-gradient(180deg, var(--red), var(--yellow));
    flex-shrink: 0;
  }

  .notice-body {
    padding: 1.5rem 2rem;
  }

  .notice-body h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .notice-body p {
    color: #666;
    line-height: 1.8;
    margin: 0;
    font-size: 0.92rem;
  }

  @media (max-width: 600px) {
    .project-body { padding: 1.25rem 1.25rem; }
    .project-body h2 { font-size: 1.1rem; }
  }
</style>
