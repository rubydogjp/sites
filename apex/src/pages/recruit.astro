---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const projects = [
  {
    name: 'Git講座',
    description: '共同開発のチュートリアル。まずはここから！',
    tags: ['Git', 'GitHub'],
    color: 'green',
    gradient: 'linear-gradient(135deg, var(--green), #2dd660)',
    url: 'https://gitnote.rubydog.jp/',
    urlLabel: 'Git講座を体験してみる',
  },
  {
    name: 'Comet',
    subtitle: 'コメット',
    description: '10 分で自分のサイトを公開できる！ Flutter で作られた静的サイトジェネレーター。',
    tags: ['Flutter'],
    color: 'blue',
    gradient: 'linear-gradient(135deg, var(--blue), #5da3ff)',
    url: 'https://comet.rubydog.jp/',
    urlLabel: 'Cometを使ってみる',
    extra: { label: '共同開発スタッフの皆様へ', url: 'https://comet.rubydog.jp/docs-jp/oss-contributing/' }
  },
  {
    name: 'AppFlowy',
    subtitle: 'アップフロウィー',
    description: 'オープンソース版の Notion として注目されています。推しの OSS として参加をサポート中。',
    tags: ['Flutter', 'Rust', 'Tauri'],
    color: 'purple',
    gradient: 'linear-gradient(135deg, #9B59B6, #c084fc)',
    url: 'https://appflowy.io/',
    urlLabel: 'AppFlowy公式サイトへ',
  },
  {
    name: 'マグネタリウム',
    description: '宇宙磁石とプラネタリウムのゲーム。',
    tags: [],
    color: 'yellow',
    gradient: 'linear-gradient(135deg, var(--yellow), #ffd04a)',
    url: null,
    urlLabel: '準備中',
  }
];

const lightColors: Record<string, string> = {
  green: 'var(--light-green)',
  blue: 'var(--light-blue)',
  purple: 'rgba(155,89,182,0.1)',
  yellow: 'var(--light-yellow)',
  red: 'var(--light-red)',
};

const darkColors: Record<string, string> = {
  green: 'var(--dark-green)',
  blue: 'var(--dark-blue)',
  purple: '#7B2D8E',
  yellow: 'var(--dark-yellow)',
  red: 'var(--dark-red)',
};
---

<PageLayout title="参加" description="共同開発プロジェクトへの参加をお待ちしています">
  <PageHeader title="コミュニティ参加" description="共同開発プロジェクトへの参加をお待ちしています" accentColor="red" />

  <div class="recruit-container">
    <!-- Intro -->
    <div class="intro-card" data-aos="fade-up">
      <div class="intro-glow"></div>
      <p>
        どなたでも気軽に参加できます。気になったプロジェクトがあれば是非ご検討ください。<br />
        どれもゆるいライセンスですので、やがては自分のものとして派生プロジェクトを作り直すことも自由です。
      </p>
    </div>

    <!-- Projects -->
    <div class="projects-grid">
      {projects.map((p, i) => (
        <article class="project-card" data-aos="fade-up" data-aos-delay={String(i * 80)}>
          <div class="project-accent" style={`background: ${p.gradient}`}>
            <div class="accent-particle p1"></div>
            <div class="accent-particle p2"></div>
          </div>
          <div class="project-body">
            <h2>
              {p.name}
              {p.subtitle && <span class="project-sub">{p.subtitle}</span>}
            </h2>
            <p class="project-desc">{p.description}</p>
            {p.tags.length > 0 && (
              <div class="tag-row">
                {p.tags.map(tag => (
                  <span class="tag" style={`background: ${lightColors[p.color]}; color: ${darkColors[p.color]}`}>{tag}</span>
                ))}
              </div>
            )}
            <div class="project-actions">
              {p.url ? (
                <a href={p.url} target="_blank" rel="noopener noreferrer" class="action-btn" style={`background: ${p.gradient}`} data-magnetic>
                  {p.urlLabel}
                </a>
              ) : (
                <span class="action-btn disabled">{p.urlLabel}</span>
              )}
              {p.extra && (
                <a href={p.extra.url} target="_blank" rel="noopener noreferrer" class="action-btn secondary" data-magnetic>
                  {p.extra.label}
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Recruitment Notice -->
    <div class="notice-card" data-aos="fade-up">
      <div class="notice-rainbow"></div>
      <div class="notice-body">
        <h3>採用情報</h3>
        <p>
          弊コミュニティにご関心いただき、誠にありがとうございます。<br />
          現在、有給でのスタッフの求人募集は行っておりません。募集の際は当ページにてご案内いたします。
        </p>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .recruit-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  /* Intro */
  .intro-card {
    position: relative;
    overflow: hidden;
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.8);
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
  }
  .intro-glow {
    position: absolute;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: var(--light-red);
    filter: blur(60px);
    opacity: 0.3;
    top: -40px;
    right: -40px;
  }
  .intro-card p {
    color: #555;
    line-height: 1.8;
    margin: 0;
    font-size: 0.95rem;
    position: relative;
    z-index: 1;
  }

  /* Projects */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .project-card {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.8);
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .project-accent {
    height: 5px;
    position: relative;
    overflow: hidden;
  }
  .accent-particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    animation: particleDrift 5s ease-in-out infinite;
  }
  .p1 { top: 0; left: 30%; }
  .p2 { top: 0; right: 20%; animation-delay: -2.5s; }
  @keyframes particleDrift {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }
    50% { transform: translateY(-4px) scale(1.5); opacity: 0.7; }
  }

  .project-body {
    padding: 1.5rem;
  }

  .project-body h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .project-sub {
    font-size: 0.8rem;
    color: #999;
    font-weight: 400;
    margin-left: 0.4rem;
  }

  .project-desc {
    color: #555;
    line-height: 1.7;
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .tag {
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: 'Courier New', monospace;
  }

  .project-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .action-btn {
    display: inline-block;
    padding: 0.55rem 1.2rem;
    color: white;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.82rem;
    transition: all 0.25s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .action-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .action-btn.secondary {
    background: #555 !important;
    font-size: 0.78rem;
  }
  .action-btn.disabled {
    background: #ccc !important;
    cursor: default;
    box-shadow: none;
  }
  .action-btn.disabled:hover {
    transform: none;
    box-shadow: none;
  }

  /* Notice */
  .notice-card {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.8);
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    overflow: hidden;
  }

  .notice-rainbow {
    height: 3px;
    background: linear-gradient(90deg, var(--red), var(--yellow), var(--green), var(--blue));
    background-size: 200% auto;
    animation: rainbowFlow 3s linear infinite;
  }
  @keyframes rainbowFlow {
    0% { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  .notice-body {
    padding: 1.5rem 2rem;
  }

  .notice-body h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .notice-body p {
    color: #666;
    line-height: 1.8;
    margin: 0;
    font-size: 0.92rem;
  }

  @media (max-width: 600px) {
    .projects-grid { grid-template-columns: 1fr; }
    .project-body { padding: 1.25rem; }
    .project-body h2 { font-size: 1.05rem; }
  }
</style>
