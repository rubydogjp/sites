---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const apps = [
  { name: 'Week', subtitle: '時間割', icon: '/products/apps/week-icon.png', url: 'https://week.rubydog.jp', detail: '/products/week', status: 'released' },
  { name: 'Timecard', subtitle: 'タイムカード', icon: '/products/timecard/timecard-icon.png', status: 'coming' },
  { name: 'Map', subtitle: 'マップ', icon: '/products/apps/map-icon.png', status: 'planned' },
  { name: 'Event', subtitle: 'イベント', icon: '/products/apps/event-icon.png', status: 'planned' },
];

const notes = [
  { name: 'Git Note', subtitle: 'Git講座', icon: '/products/notes/gitnote/gitnote-icon.svg', iconType: 'icon', url: 'https://gitnote.rubydog.jp' },
  { name: 'Flutter Note', subtitle: 'Flutter講座', icon: '/products/notes/flutternote/flutternote-profile.png', iconType: 'profile', url: 'https://flutternote.rubydog.jp' },
];
---

<PageLayout title="製品一覧" description="Rubydog JP の製品・サービス一覧">
  <PageHeader title="製品一覧" description="Rubydog JP のすべての製品・サービス" accentColor="red" />

  <section class="content">
    <!-- TOC -->
    <nav class="toc tile" data-aos="fade-up">
      <a href="#apps" class="toc-pill toc-red">アプリ</a>
      <a href="#notes" class="toc-pill toc-green">講座</a>
      <a href="#packages" class="toc-pill toc-blue">ライブラリ</a>
    </nav>

    <!-- Apps -->
    <section id="apps" class="group" data-aos="fade-up">
      <div class="group-head">
        <div class="group-icon accent-red"><img src="/products/apps/apps-icon.png" alt="アプリ" /></div>
        <div><h2>アプリ</h2><p>Rubydog JP が開発したWebアプリ</p></div>
      </div>
      <div class="items">
        {apps.map(app => (
          <div class:list={['item tile', { dim: app.status !== 'released' }]}>
            <div class="item-icon accent-red"><img src={app.icon} alt={app.name} /></div>
            <div class="item-body">
              <h3>{app.name} <span class="sub">{app.subtitle}</span></h3>
              {app.status === 'released' && app.url && <a href={app.url} target="_blank" rel="noopener noreferrer" class="item-link">開く →</a>}
              {app.status === 'coming' && <span class="badge badge-yellow">Coming Soon</span>}
              {app.status === 'planned' && <span class="badge badge-gray">準備中</span>}
            </div>
          </div>
        ))}
      </div>
      <a href="/apps" class="more-link">アプリの詳細ページへ →</a>
    </section>

    <!-- Notes -->
    <section id="notes" class="group" data-aos="fade-up">
      <div class="group-head">
        <img src="/products/notes/notes-profile.png" alt="講座" class="group-profile" />
        <div><h2>講座</h2><p>プログラミングを実践しながら学べるWeb講座</p></div>
      </div>
      <div class="items">
        {notes.map(note => (
          <div class="item tile">
            <div class:list={['item-icon', `accent-green`, { 'is-profile': note.iconType === 'profile' }]}>
              <img src={note.icon} alt={note.name} />
            </div>
            <div class="item-body">
              <h3>{note.name} <span class="sub">{note.subtitle}</span></h3>
              <a href={note.url} target="_blank" rel="noopener noreferrer" class="item-link">開く →</a>
            </div>
          </div>
        ))}
      </div>
      <a href="/notes" class="more-link">講座の詳細ページへ →</a>
    </section>

    <!-- Packages -->
    <section id="packages" class="group" data-aos="fade-up">
      <div class="group-head">
        <div class="group-icon accent-blue"><img src="/img/icon.png" alt="ライブラリ" /></div>
        <div><h2>ライブラリ</h2><p>開発者向けのパッケージやライブラリ</p></div>
      </div>
      <div class="coming-box tile">準備中です。今後ライブラリやパッケージを公開予定です。</div>
      <a href="/packages" class="more-link">ライブラリの詳細ページへ →</a>
    </section>
  </section>
</PageLayout>

<style>
  .content { max-width: 800px; margin: 0 auto; padding: 1rem 1.5rem 4rem; }

  .tile {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(12px);
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.8);
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    transition: all 0.3s;
  }

  /* TOC */
  .toc { display: flex; gap: 0.5rem; justify-content: center; padding: 0.8rem; margin-bottom: 2.5rem; border-radius: 14px; }
  .toc-pill { padding: 0.5rem 1.5rem; border-radius: 10px; font-weight: 600; font-size: 0.85rem; color: white; transition: all 0.2s; }
  .toc-pill:hover { transform: scale(1.05); }
  .toc-red { background: var(--red); }
  .toc-green { background: var(--green); }
  .toc-blue { background: var(--blue); }

  /* Groups */
  .group { margin-bottom: 3rem; }
  .group-head { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  .group-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .group-icon img { width: 32px; height: 32px; object-fit: contain; }
  .group-profile { width: 52px; height: 52px; border-radius: 14px; object-fit: cover; flex-shrink: 0; }
  .accent-red { background: var(--light-red); }
  .accent-green { background: var(--light-green); }
  .accent-blue { background: var(--light-blue); }
  .group-head h2 { font-size: 1.4rem; font-weight: 700; margin: 0; }
  .group-head p { color: #888; font-size: 0.85rem; margin: 0.15rem 0 0; }

  /* Items */
  .items { display: flex; flex-direction: column; gap: 0.75rem; }
  .item { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem; }
  .item:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.06); }
  .dim { opacity: 0.6; }
  .item-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
  .item-icon img { width: 28px; height: 28px; object-fit: contain; }
  .item-icon.is-profile img { width: 100%; height: 100%; object-fit: cover; }
  .item-body { flex: 1; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .item-body h3 { font-size: 1rem; font-weight: 600; margin: 0; }
  .sub { font-size: 0.75rem; color: #999; font-weight: 400; margin-left: 0.3rem; }
  .item-link { color: var(--red); font-weight: 600; font-size: 0.8rem; margin-left: auto; }
  .badge { padding: 0.15rem 0.6rem; border-radius: 6px; font-size: 0.65rem; font-weight: 600; margin-left: auto; }
  .badge-yellow { background: var(--light-yellow); color: var(--dark-yellow); }
  .badge-gray { background: #f0f0f0; color: #999; }

  .coming-box { text-align: center; padding: 2rem; color: #999; border: 2px dashed rgba(0,0,0,0.06); }
  .more-link { display: block; text-align: right; margin-top: 0.75rem; color: var(--red); font-weight: 600; font-size: 0.85rem; }

  @media (max-width: 768px) {
    .toc { flex-direction: column; align-items: center; }
    .group-head { flex-direction: column; text-align: center; }
  }
</style>
