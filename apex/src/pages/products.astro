---
import PageLayout from '../layouts/PageLayout.astro';

const apps = [
  {
    name: 'Week',
    subtitle: '時間割',
    description: '生活リズムを整えるシンプルな時間割表アプリ',
    icon: '/products/apps/week-icon.png',
    iconType: 'icon',
    url: 'https://week.rubydog.jp',
    detail: '/products/week',
    status: 'released'
  },
  {
    name: 'Timecard',
    subtitle: 'タイムカード',
    description: '新しいアプリ（近日アナウンス予定）',
    icon: '/products/apps/timecard-icon.png',
    iconType: 'icon',
    status: 'coming'
  },
  {
    name: 'Map',
    subtitle: 'マップ',
    description: '準備中',
    icon: '/products/apps/map-icon.png',
    iconType: 'icon',
    status: 'planned'
  },
  {
    name: 'Event',
    subtitle: 'イベント',
    description: '準備中',
    icon: '/products/apps/event-icon.png',
    iconType: 'icon',
    status: 'planned'
  }
];

const notes = [
  {
    name: 'Git Note',
    subtitle: 'Git講座',
    description: 'Git・GitHubの使い方を実践しながら学べるWeb講座',
    icon: '/products/notes/gitnote/gitnote-icon.svg',
    iconType: 'icon',
    url: 'https://gitnote.rubydog.jp',
    status: 'released'
  },
  {
    name: 'Flutter Note',
    subtitle: 'Flutter講座',
    description: 'Flutter入門動画と実践リソース',
    icon: '/products/notes/flutternote/flutternote-profile.png',
    iconType: 'profile',
    url: 'https://flutternote.rubydog.jp',
    status: 'released'
  }
];
---

<PageLayout title="製品一覧" description="Rubydog JP の製品・サービス一覧">
  <div class="products-page">
    <!-- TOC -->
    <nav class="toc">
      <a href="#apps" class="toc-link">アプリ</a>
      <a href="#notes" class="toc-link">講座</a>
      <a href="#packages" class="toc-link">ライブラリ</a>
    </nav>

    <!-- Apps Section -->
    <section id="apps" class="group-section">
      <div class="group-header">
        <div class="icon-frame"><img src="/products/apps/apps-icon.png" alt="アプリ" /></div>
        <div>
          <h2 class="group-title">アプリ</h2>
          <p class="group-description">Rubydog JP が開発したWebアプリ</p>
        </div>
      </div>
      <div class="items-grid">
        {apps.map(app => (
          <div class:list={['item-card', { 'item-coming': app.status !== 'released' }]}>
            {app.iconType === 'icon' ? (
              <div class="icon-frame"><img src={app.icon} alt={app.name} /></div>
            ) : (
              <img src={app.icon} alt={app.name} class="item-profile" />
            )}
            <div class="item-info">
              <h3 class="item-name">{app.name} <span class="item-subtitle">{app.subtitle}</span></h3>
              <p class="item-description">{app.description}</p>
              {app.status === 'released' && (
                <div class="item-actions">
                  {app.url && <a href={app.url} target="_blank" rel="noopener noreferrer" class="item-button primary">開く</a>}
                  {app.detail && <a href={app.detail} class="item-button secondary">詳しく</a>}
                </div>
              )}
              {app.status === 'coming' && <span class="status-badge coming">Coming Soon</span>}
              {app.status === 'planned' && <span class="status-badge planned">準備中</span>}
            </div>
          </div>
        ))}
      </div>
      <div class="group-link">
        <a href="/apps">アプリの詳細ページへ</a>
      </div>
    </section>

    <!-- Notes Section -->
    <section id="notes" class="group-section">
      <div class="group-header">
        <img src="/products/notes/notes-profile.png" alt="講座" class="group-profile" />
        <div>
          <h2 class="group-title">講座</h2>
          <p class="group-description">プログラミングを実践しながら学べるWeb講座</p>
        </div>
      </div>
      <div class="items-grid">
        {notes.map(note => (
          <div class="item-card">
            {note.iconType === 'icon' ? (
              <div class="icon-frame"><img src={note.icon} alt={note.name} /></div>
            ) : (
              <img src={note.icon} alt={note.name} class="item-profile" />
            )}
            <div class="item-info">
              <h3 class="item-name">{note.name} <span class="item-subtitle">{note.subtitle}</span></h3>
              <p class="item-description">{note.description}</p>
              <div class="item-actions">
                <a href={note.url} target="_blank" rel="noopener noreferrer" class="item-button primary">開く</a>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="group-link">
        <a href="/notes">講座の詳細ページへ</a>
      </div>
    </section>

    <!-- Packages Section -->
    <section id="packages" class="group-section">
      <div class="group-header">
        <div class="icon-frame"><img src="/img/icon.png" alt="ライブラリ" /></div>
        <div>
          <h2 class="group-title">ライブラリ</h2>
          <p class="group-description">開発者向けのパッケージやライブラリ</p>
        </div>
      </div>
      <div class="placeholder-box">
        <p>準備中です。今後ライブラリやパッケージを公開予定です。</p>
      </div>
      <div class="group-link">
        <a href="/packages">ライブラリの詳細ページへ</a>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .products-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .toc {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 3rem;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 12px;
  }

  .toc-link {
    padding: 0.5rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    color: #666;
    font-weight: 500;
    transition: all 0.2s;
  }

  .toc-link:hover {
    background: #e9ecef;
    color: #EA4036;
  }

  .group-section {
    margin-bottom: 4rem;
  }

  .group-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #EA4036;
  }

  /* icon 系: 白背景 + 余白の中に配置 */
  .icon-frame {
    width: 64px;
    height: 64px;
    background: white;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    flex-shrink: 0;
  }

  .icon-frame img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  /* profile 系: そのまま角丸OK */
  .group-profile {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: 16px;
    flex-shrink: 0;
  }

  .item-profile {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: 16px;
    flex-shrink: 0;
  }

  .group-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }

  .group-description {
    color: #666;
    margin: 0.25rem 0 0;
  }

  .items-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .item-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    background: white;
    border-radius: 12px;
    border: 1px solid #e9ecef;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
    transition: all 0.2s;
  }

  .item-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }

  .item-coming {
    opacity: 0.7;
  }

  .item-info { flex: 1; }

  .item-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .item-subtitle {
    font-size: 0.8rem;
    color: #999;
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .item-description {
    color: #666;
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  .item-actions {
    display: flex;
    gap: 0.75rem;
  }

  .item-button {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .item-button.primary {
    background: #EA4036;
    color: #fff;
  }

  .item-button.primary:hover {
    background: #d63630;
    transform: translateY(-2px);
  }

  .item-button.secondary {
    background: #e9ecef;
    color: #333;
  }

  .item-button.secondary:hover {
    background: #dee2e6;
    transform: translateY(-2px);
  }

  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .status-badge.coming {
    background: #fff3cd;
    color: #856404;
  }

  .status-badge.planned {
    background: #e9ecef;
    color: #666;
  }

  .placeholder-box {
    background: #f8f9fa;
    border: 2px dashed #dee2e6;
    border-radius: 12px;
    padding: 3rem;
    text-align: center;
    color: #999;
  }

  .group-link {
    margin-top: 1rem;
    text-align: right;
  }

  .group-link a {
    color: #EA4036;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
  }

  .group-link a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .products-page { padding: 1rem; }
    .toc { flex-direction: column; align-items: center; }
    .group-header { flex-direction: column; text-align: center; }
    .item-card { flex-direction: column; align-items: center; text-align: center; }
    .item-actions { justify-content: center; }
  }
</style>
