---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<PageLayout title="ライブラリ" description="Rubydog JP が提供する開発者向けライブラリ">
  <PageHeader
    title="ライブラリ"
    description="開発者向けのパッケージやライブラリ"
    icon="/img/icon.png"
    accentColor="blue"
  />

  <section class="content">
    <div class="coming-tile tile" data-aos="fade-up">
      <div class="coming-icon">📦</div>
      <h2>準備中</h2>
      <p>今後ライブラリやパッケージを公開予定です。</p>
    </div>

    <div class="legacy-tile tile" data-aos="fade-up" data-aos-delay="150">
      <p>過去に公開した Flutter パッケージのデモサイト</p>
      <a href="https://rubydogjp-packages.web.app" target="_blank" rel="noopener noreferrer" class="btn" data-magnetic>
        デモサイトへ移動 →
      </a>
    </div>
  </section>
</PageLayout>

<style>
  .content { max-width: 600px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

  .tile {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(12px);
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.8);
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    transition: all 0.3s;
  }

  .coming-tile {
    text-align: center; padding: 4rem 2rem; margin-bottom: 1.5rem;
    border: 2px dashed rgba(0,0,0,0.08);
    background: linear-gradient(135deg, rgba(208,231,255,0.3), rgba(184,244,208,0.3));
  }
  .coming-icon { font-size: 3rem; margin-bottom: 1rem; }
  .coming-tile h2 { font-size: 1.5rem; font-weight: 700; margin: 0 0 0.5rem; }
  .coming-tile p { color: #888; }

  .legacy-tile { padding: 2rem; text-align: center; }
  .legacy-tile p { color: #888; margin: 0 0 1rem; font-size: 0.9rem; }
  .btn {
    display: inline-block; padding: 0.7rem 2rem; border-radius: 12px;
    background: var(--blue); color: white; font-weight: 600; font-size: 0.9rem;
    transition: all 0.2s; box-shadow: 0 4px 12px rgba(37,132,252,0.15);
  }
  .btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(37,132,252,0.25); }
</style>
