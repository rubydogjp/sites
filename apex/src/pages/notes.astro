---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Flutter Note" description="Flutter 教材アプリ">
  <div class="redirect-container">
    <div class="redirect-card">
      <div class="redirect-icon">&#x1F4DD;</div>
      <h1 class="redirect-title">Flutter Note</h1>
      <p class="redirect-description">
        Flutter の基礎から実践まで学べる教材アプリです。<br />
        ブラウザ上でサンプルコードを確認しながら学習できます。
      </p>
      <a href="https://flutter-note.rubydog.jp" class="redirect-button">
        flutter-note.rubydog.jp へ移動
      </a>
    </div>
  </div>
</PageLayout>

<style>
  .redirect-container {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1rem;
  }

  .redirect-card {
    text-align: center;
    max-width: 480px;
  }

  .redirect-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .redirect-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 1rem;
  }

  .redirect-description {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 2rem;
  }

  .redirect-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: #EA4036;
    color: white;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s;
  }

  .redirect-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(234, 64, 54, 0.3);
  }
</style>
