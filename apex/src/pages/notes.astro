---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const notes = [
  {
    name: 'Git Note',
    subtitle: 'Git講座',
    description: 'Git・GitHubの使い方を実践しながら学べるWeb講座です。ハチミツと蜂の巣をテーマにした温かみのあるデザインで、初心者でも楽しく学べます。',
    icon: '/products/notes/gitnote/gitnote-icon.svg',
    iconType: 'icon' as const,
    image: '/products/notes/gitnote/gitnote-renewal-pr.png',
    url: 'https://gitnote.rubydog.jp',
    features: ['ブラウザだけで手軽に始められる', 'ステップバイステップのチュートリアル', 'フォーク・クローン・プルリクエストまで実践', 'Git・GitHubの基礎を体験で学ぶ'],
    accent: 'green',
    gradient: 'linear-gradient(135deg, var(--green), #2dd660)',
  },
  {
    name: 'Flutter Note',
    subtitle: 'Flutter講座',
    description: 'Flutter入門動画や実践リソースをまとめたプロジェクトです。動画で学び、パッケージやテンプレートを活用できます。',
    icon: '/products/notes/flutternote/flutternote-profile.png',
    iconType: 'profile' as const,
    url: 'https://flutternote.rubydog.jp',
    features: ['入門動画の編集・投稿', 'パッケージのリリース・メンテナンス', 'アプリのテンプレート配布', '技術記事の投稿'],
    accent: 'blue',
    gradient: 'linear-gradient(135deg, var(--blue), #5da3ff)',
  }
];
---

<PageLayout title="講座" description="Rubydog JP が提供するプログラミング講座">
  <PageHeader
    title="講座"
    description="プログラミングを実践しながら学べるWeb講座"
    icon="/products/notes/notes-profile.png"
    iconType="profile"
    accentColor="green"
  />

  <section class="content">
    {notes.map((note, i) => (
      <div class="note-card" data-aos="fade-up" data-aos-delay={String(i * 150)}>
        <!-- Accent tile top bar -->
        <div class="card-accent" style={`background: ${note.gradient}`}>
          <div class="accent-particle p1"></div>
          <div class="accent-particle p2"></div>
          <div class="accent-particle p3"></div>
          <div class={`card-icon ${note.iconType === 'profile' ? 'is-profile' : ''}`}>
            <img src={note.icon} alt={note.name} />
          </div>
          <div class="accent-info">
            <h2>{note.name}</h2>
            <span class="accent-sub">{note.subtitle}</span>
          </div>
        </div>

        <div class="card-body">
          <p class="note-desc">{note.description}</p>
          {note.image && (
            <div class="note-image" data-aos="zoom-in">
              <img src={note.image} alt={note.name} />
            </div>
          )}
          <ul class="features">
            {note.features.map(f => (
              <li>
                <span class="feature-dot" style={`background: var(--${note.accent})`}></span>
                {f}
              </li>
            ))}
          </ul>
          <a href={note.url} target="_blank" rel="noopener noreferrer" class={`btn btn-${note.accent}`} data-magnetic>
            講座を開く →
          </a>
        </div>
      </div>
    ))}
  </section>
</PageLayout>

<style>
  .content { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

  .note-card {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 22px;
    border: 1px solid rgba(255,255,255,0.8);
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    overflow: hidden;
    margin-bottom: 1.5rem;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .note-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,0.08); transform: translateY(-2px); }

  /* Accent top bar */
  .card-accent {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 2rem;
    color: white;
    position: relative;
    overflow: hidden;
  }
  .accent-particle {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    animation: particleDrift 6s ease-in-out infinite;
  }
  .p1 { top: 20%; right: 15%; animation-delay: 0s; }
  .p2 { top: 60%; right: 30%; animation-delay: -2s; }
  .p3 { bottom: 20%; right: 50%; animation-delay: -4s; }
  @keyframes particleDrift {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }
    50% { transform: translateY(-8px) scale(1.3); opacity: 0.6; }
  }

  .card-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; overflow: hidden;
  }
  .card-icon img { width: 32px; height: 32px; object-fit: contain; filter: brightness(0) invert(1); }
  .card-icon.is-profile img { width: 100%; height: 100%; object-fit: cover; filter: none; border-radius: 14px; }

  .accent-info { position: relative; z-index: 1; }
  .accent-info h2 { font-size: 1.4rem; font-weight: 700; margin: 0; }
  .accent-sub { font-size: 0.8rem; opacity: 0.8; }

  /* Card body */
  .card-body { padding: 1.5rem 2rem 2rem; }
  .note-desc { color: #555; line-height: 1.7; margin: 0 0 1rem; }

  .note-image {
    border-radius: 14px; overflow: hidden; margin-bottom: 1.5rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    transition: box-shadow 0.3s;
  }
  .note-image:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.1); }
  .note-image img { width: 100%; height: auto; display: block; }

  .features { list-style: none; padding: 0; color: #555; margin: 0 0 1.5rem; }
  .features li {
    display: flex; align-items: center; gap: 0.6rem;
    margin-bottom: 0.5rem; line-height: 1.6;
  }
  .feature-dot {
    width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
  }

  .btn {
    display: inline-block; padding: 0.75rem 2rem; border-radius: 12px;
    font-weight: 600; font-size: 0.9rem; color: white; transition: all 0.25s;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-green { background: var(--green); box-shadow: 0 4px 16px rgba(5,172,71,0.2); }
  .btn-green:hover { box-shadow: 0 8px 24px rgba(5,172,71,0.3); }
  .btn-blue { background: var(--blue); box-shadow: 0 4px 16px rgba(37,132,252,0.2); }
  .btn-blue:hover { box-shadow: 0 8px 24px rgba(37,132,252,0.3); }

  @media (max-width: 600px) {
    .card-accent { padding: 1.2rem 1.5rem; }
    .card-body { padding: 1.2rem 1.5rem 1.5rem; }
  }
</style>
