---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const notes = [
  {
    name: 'Git Note',
    subtitle: 'Git講座',
    description: 'Git・GitHubの使い方を実践しながら学べるWeb講座です。ハチミツと蜂の巣をテーマにした温かみのあるデザインで、初心者でも楽しく学べます。',
    icon: '/products/notes/gitnote/gitnote-icon.svg',
    iconType: 'icon' as const,
    image: '/products/notes/gitnote/gitnote-renewal-pr.png',
    url: 'https://gitnote.rubydog.jp',
    features: ['ブラウザだけで手軽に始められる', 'ステップバイステップのチュートリアル', 'フォーク・クローン・プルリクエストまで実践', 'Git・GitHubの基礎を体験で学ぶ'],
    accent: 'green'
  },
  {
    name: 'Flutter Note',
    subtitle: 'Flutter講座',
    description: 'Flutter入門動画や実践リソースをまとめたプロジェクトです。動画で学び、パッケージやテンプレートを活用できます。',
    icon: '/products/notes/flutternote/flutternote-profile.png',
    iconType: 'profile' as const,
    url: 'https://flutternote.rubydog.jp',
    features: ['入門動画の編集・投稿', 'パッケージのリリース・メンテナンス', 'アプリのテンプレート配布', '技術記事の投稿'],
    accent: 'blue'
  }
];
---

<PageLayout title="講座" description="Rubydog JP が提供するプログラミング講座">
  <PageHeader
    title="講座"
    description="プログラミングを実践しながら学べるWeb講座"
    icon="/products/notes/notes-profile.png"
    iconType="profile"
    accentColor="green"
  />

  <section class="content">
    {notes.map((note, i) => (
      <div class="note-card tile" data-aos="fade-up" data-aos-delay={String(i * 150)}>
        <div class="note-top">
          <div class={`note-icon accent-${note.accent} ${note.iconType === 'profile' ? 'is-profile' : ''}`}>
            <img src={note.icon} alt={note.name} />
          </div>
          <div>
            <h2>{note.name} <span class="sub">{note.subtitle}</span></h2>
          </div>
        </div>
        <p class="note-desc">{note.description}</p>
        {note.image && (
          <div class="note-image" data-aos="zoom-in">
            <img src={note.image} alt={note.name} />
          </div>
        )}
        <ul class="features">
          {note.features.map(f => <li>{f}</li>)}
        </ul>
        <a href={note.url} target="_blank" rel="noopener noreferrer" class={`btn btn-${note.accent}`} data-magnetic>
          講座を開く →
        </a>
      </div>
    ))}
  </section>
</PageLayout>

<style>
  .content { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

  .tile {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(12px);
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.8);
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    transition: all 0.3s;
  }
  .tile:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); }

  .note-card { padding: 2rem; margin-bottom: 1.5rem; }

  .note-top { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .note-icon {
    width: 60px; height: 60px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden;
  }
  .note-icon img { width: 38px; height: 38px; object-fit: contain; }
  .note-icon.is-profile img { width: 100%; height: 100%; object-fit: cover; }
  .accent-green { background: var(--light-green); }
  .accent-blue { background: var(--light-blue); }

  .note-top h2 { font-size: 1.4rem; font-weight: 700; margin: 0; }
  .sub { font-size: 0.8rem; color: #999; font-weight: 400; margin-left: 0.4rem; }

  .note-desc { color: #555; line-height: 1.7; margin: 0 0 1rem; }

  .note-image { border-radius: 14px; overflow: hidden; margin-bottom: 1.5rem; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
  .note-image img { width: 100%; height: auto; display: block; }

  .features { padding-left: 1.2rem; color: #555; margin: 0 0 1.5rem; }
  .features li { margin-bottom: 0.4rem; line-height: 1.6; }

  .btn {
    display: inline-block; padding: 0.7rem 2rem; border-radius: 12px;
    font-weight: 600; font-size: 0.9rem; color: white; transition: all 0.2s;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-green { background: var(--green); box-shadow: 0 4px 12px rgba(5,172,71,0.2); }
  .btn-green:hover { box-shadow: 0 6px 20px rgba(5,172,71,0.3); }
  .btn-blue { background: var(--blue); box-shadow: 0 4px 12px rgba(37,132,252,0.2); }
  .btn-blue:hover { box-shadow: 0 6px 20px rgba(37,132,252,0.3); }
</style>
