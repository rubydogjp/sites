---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="ページが見つかりません" description="お探しのページは存在しません">
  <div class="not-found">
    <div class="bg-blocks">
      <div class="bg-block bg-1"></div>
      <div class="bg-block bg-2"></div>
      <div class="bg-block bg-3"></div>
    </div>
    <div class="grain"></div>
    <div class="card" data-aos="zoom-in">
      <div class="code rainbow-text">404</div>
      <h1>ページが見つかりません</h1>
      <p>お探しのページは存在しないか、移動した可能性があります。</p>
      <a href="/" class="btn" data-magnetic>トップページへ戻る</a>
    </div>
  </div>
</PageLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .bg-blocks {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .bg-block {
    position: absolute;
    border-radius: 40px;
    opacity: 0.07;
    animation: blockFloat 16s ease-in-out infinite;
  }
  .bg-1 { width: 45%; height: 55%; background: var(--red); top: -10%; left: -10%; animation-duration: 18s; }
  .bg-2 { width: 35%; height: 45%; background: var(--blue); bottom: -10%; right: -8%; animation-delay: -5s; animation-direction: reverse; }
  .bg-3 { width: 20%; height: 30%; background: var(--yellow); top: 30%; right: 25%; opacity: 0.04; animation-delay: -8s; animation-duration: 20s; }
  @keyframes blockFloat {
    0%, 100% { transform: scale(1) translate(0, 0); }
    33% { transform: scale(1.06) translate(8px, -5px); }
    66% { transform: scale(0.97) translate(-5px, 8px); }
  }

  .grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    opacity: 0.4;
    pointer-events: none;
  }

  .card { text-align: center; max-width: 480px; position: relative; z-index: 1; }

  .code {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  h1 { font-size: 1.6rem; font-weight: 700; color: #1a1a1a; margin: 0 0 0.75rem; }
  p { font-size: 1rem; line-height: 1.7; color: #888; margin: 0 0 2rem; }

  .btn {
    display: inline-block; padding: 0.9rem 2.5rem;
    border-radius: 14px; background: var(--red); color: white;
    font-weight: 700; font-size: 1rem; transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(234,64,54,0.2);
  }
  .btn:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(234,64,54,0.3); }
</style>
