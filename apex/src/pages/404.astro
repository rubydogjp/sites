---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="ページが見つかりません" description="お探しのページは存在しません">
  <div class="not-found-container">
    <div class="not-found-card">
      <div class="not-found-code">404</div>
      <h1 class="not-found-title">ページが見つかりません</h1>
      <p class="not-found-description">
        お探しのページは存在しないか、移動した可能性があります。
      </p>
      <a href="/" class="not-found-button">
        トップページへ戻る
      </a>
    </div>
  </div>
</PageLayout>

<style>
  .not-found-container {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1rem;
  }

  .not-found-card {
    text-align: center;
    max-width: 480px;
  }

  .not-found-code {
    font-size: 8rem;
    font-weight: 800;
    color: #EA4036;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .not-found-title {
    font-size: 2rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 1rem;
  }

  .not-found-description {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 2rem;
  }

  .not-found-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: #EA4036;
    color: white;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s;
  }

  .not-found-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(234, 64, 54, 0.3);
  }
</style>
