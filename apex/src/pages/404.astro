---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="ページが見つかりません" description="お探しのページは存在しません">
  <div class="not-found">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="card" data-aos="zoom-in">
      <div class="code rainbow-text">404</div>
      <h1>ページが見つかりません</h1>
      <p>お探しのページは存在しないか、移動した可能性があります。</p>
      <a href="/" class="btn" data-magnetic>トップページへ戻る</a>
    </div>
  </div>
</PageLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.1;
    pointer-events: none;
  }
  .orb-1 { width: 400px; height: 400px; background: var(--red); top: 10%; left: 10%; }
  .orb-2 { width: 300px; height: 300px; background: var(--blue); bottom: 10%; right: 15%; }

  .card { text-align: center; max-width: 480px; position: relative; z-index: 1; }

  .code {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  h1 { font-size: 1.6rem; font-weight: 700; color: #1a1a1a; margin: 0 0 0.75rem; }
  p { font-size: 1rem; line-height: 1.7; color: #888; margin: 0 0 2rem; }

  .btn {
    display: inline-block; padding: 0.9rem 2.5rem;
    border-radius: 14px; background: var(--red); color: white;
    font-weight: 700; font-size: 1rem; transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(234,64,54,0.2);
  }
  .btn:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(234,64,54,0.3); }
</style>
