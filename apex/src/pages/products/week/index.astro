---
import PageLayout from '../../../layouts/PageLayout.astro';

const pageTitle = 'Week - 個人向けの時間割表';
const pageDescription = '社会人も学生みたいに時間割表が欲しい！生活リズムを整えるために使うシンプルな時間割表アプリです。ログイン不要ですぐに使えて、作成した時間割は画像として保存できます。';
const appUrl = 'https://week.rubydog.jp';
const ogImageUrl = 'https://rubydog.jp/products/week/pr-main-image.png';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Week',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Web Browser',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
  description: pageDescription,
  url: appUrl,
  screenshot: ogImageUrl,
  author: { '@type': 'Person', name: 'ルビーDog' }
};

const features = [
  {
    title: '気軽に！簡単に！',
    desc: 'ログイン不要ですぐに使えます。データを保存したい場合は、Googleアカウントでログインすることも可能です。思い立ったその瞬間から、あなたの時間割作成を始められます。',
    img: '/products/week/pr-sub1.png',
    alt: 'ログイン不要ですぐに使えるWeekの画面',
    color: 'red',
  },
  {
    title: '生活リズムを整える！',
    desc: '特に睡眠時間の習慣化は重要です。その他習慣化したいスケジュールだけ入力しておくのもおすすめです。規則正しい生活で、より良い毎日を送りましょう。',
    img: '/products/week/pr-sub2.png',
    alt: '生活リズムを整えるための時間割設定画面',
    color: 'yellow',
  },
  {
    title: '便利に！',
    desc: '作成した時間割は画像として保存できます。目的を問わず利用可能です。スマホの壁紙にしたり、SNSでシェアしたり、自由に活用できます。',
    img: '/products/week/pr-sub3.png',
    alt: '時間割を画像として保存する機能',
    color: 'green',
  },
  {
    title: '自由に！',
    desc: '旅行やイベントの日程共有にも使えます。好きなように使ってください。アイデア次第で、時間割表の可能性は無限大です。',
    img: '/products/week/pr-sub4.png',
    alt: '旅行やイベントにも使える柔軟な時間割',
    color: 'blue',
  }
];
---

<PageLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content="https://rubydog.jp/products/week" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Rubydog JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="keywords" content="時間割表,タイムテーブル,生活リズム,習慣化,スケジュール管理,無料アプリ,ログイン不要" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <div class="week-page">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-block hero-block-1"></div>
        <div class="hero-block hero-block-2"></div>
        <div class="hero-block hero-block-3"></div>
      </div>
      <div class="hero-grain"></div>
      <div class="hero-content">
        <div class="hero-text" data-aos="fade-right" data-aos-duration="800">
          <div class="hero-title-row">
            <img src="/products/week/app-icon.png" alt="Week アイコン" class="app-icon" />
            <h1>Week</h1>
          </div>
          <p class="hero-subtitle">個人向けの時間割表</p>
          <p class="hero-desc">
            社会人も学生みたいに時間割表が欲しい！<br />
            生活リズムを整えるために使うシンプルな時間割表アプリです。
          </p>
          <div class="warning-bubble">
            <p>【Xから来てくれた人へ】<br/>アプリがうまく読み込めない場合は、右上のメニューから<strong>再読み込み</strong>するか、<strong>別のブラウザで開いて</strong>ください。</p>
          </div>
          <a href={appUrl} target="_blank" rel="noopener noreferrer" class="hero-cta" data-magnetic>
            アプリを開く
          </a>
        </div>
        <div class="hero-media" data-aos="fade-left" data-aos-duration="800" data-aos-delay="200">
          <video autoplay loop muted playsinline poster="/products/week/pr-main-image.png" aria-label="Weekアプリのデモ動画">
            <source src="/products/week/pr-main-video.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </section>

    <!-- Rainbow divider -->
    <div class="rainbow-divider">
      <div class="rainbow-bar"></div>
    </div>

    <!-- Features -->
    <section class="features-section">
      <div class="features-header" data-aos="fade-up">
        <span class="section-tag">Features</span>
        <h2>主な機能</h2>
      </div>
      {features.map((f, i) => (
        <article class:list={['feature-row', { reverse: i % 2 === 1 }]} data-aos="fade-up" data-aos-delay={String(i * 80)}>
          <div class="feature-text">
            <div class={`feature-bar bar-${f.color}`}></div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
          <div class="feature-img-wrap">
            <div class={`feature-glow glow-${f.color}`}></div>
            <img src={f.img} alt={f.alt} loading="lazy" width="1920" height="1080" />
          </div>
        </article>
      ))}
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="cta-bg">
        <div class="cta-block cta-block-1"></div>
        <div class="cta-block cta-block-2"></div>
      </div>
      <div class="cta-grain"></div>
      <div class="cta-inner" data-aos="fade-up">
        <h2>今すぐ始めましょう</h2>
        <p>登録不要で使える、完全無料のアプリ。データを保存したい場合はログインも可能です。</p>
        <div class="warning-bubble cta-warning">
          <p>【Xからお越しの方へ】<br/>正常に読み込めない場合は、右上のメニューから<strong>再読み込み</strong>するか、<strong>別のブラウザで開いて</strong>ください。</p>
        </div>
        <a href={appUrl} target="_blank" rel="noopener noreferrer" class="cta-btn" data-magnetic>
          アプリを開く
        </a>
      </div>
    </section>

    <!-- Links -->
    <nav class="links-bar" aria-label="関連リンク">
      <a href="/apps/privacy">プライバシーポリシー</a>
      <a href="/apps/terms">利用規約</a>
    </nav>
  </div>
</PageLayout>

<style>
  .week-page { width: 100%; }

  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .hero-block {
    position: absolute;
    border-radius: 40px;
    opacity: 0.07;
    animation: blockFloat 16s ease-in-out infinite;
  }
  .hero-block-1 { width: 50%; height: 60%; background: var(--red); top: -15%; right: -10%; animation-duration: 18s; }
  .hero-block-2 { width: 40%; height: 50%; background: var(--yellow); bottom: -12%; left: -8%; animation-delay: -5s; animation-direction: reverse; }
  .hero-block-3 { width: 25%; height: 35%; background: var(--blue); top: 20%; left: 30%; opacity: 0.04; animation-delay: -8s; animation-duration: 20s; }
  @keyframes blockFloat {
    0%, 100% { transform: scale(1) translate(0, 0); }
    33% { transform: scale(1.06) translate(8px, -5px); }
    66% { transform: scale(0.97) translate(-5px, 8px); }
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-content {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-text { display: flex; flex-direction: column; gap: 1rem; }

  .hero-title-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .app-icon {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    background: white;
    padding: 6px;
    box-sizing: border-box;
  }

  .hero-title-row h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #1a1a1a;
    margin: 0;
  }

  .hero-subtitle {
    font-size: 1.3rem;
    color: var(--red);
    font-weight: 600;
    margin: 0;
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #555;
    margin: 0;
  }

  .hero-cta {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: var(--red);
    color: white;
    border-radius: 14px;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(234,64,54,0.2);
    align-self: flex-start;
  }
  .hero-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(234,64,54,0.3);
  }

  .hero-media video {
    width: 100%;
    max-width: 480px;
    border-radius: 20px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.12);
    display: block;
    margin: 0 auto;
  }

  /* Warning Bubble */
  .warning-bubble {
    background: rgba(255,186,0,0.1);
    border: 1px solid rgba(255,186,0,0.3);
    border-radius: 12px;
    padding: 0.8rem 1.2rem;
    max-width: 460px;
  }
  .warning-bubble p {
    margin: 0;
    color: #775a00;
    font-size: 0.88rem;
    line-height: 1.6;
    font-weight: 500;
  }
  .warning-bubble p strong { font-weight: 700; }
  .cta-warning { margin: 0 auto 1.5rem; }

  /* Rainbow divider */
  .rainbow-divider { padding: 0 1.5rem; }
  .rainbow-bar {
    height: 3px;
    border-radius: 3px;
    max-width: 1100px;
    margin: 0 auto;
    background: linear-gradient(90deg, var(--red), var(--yellow), var(--green), var(--blue), var(--red));
    background-size: 200% auto;
    animation: rainbowFlow 3s linear infinite;
  }
  @keyframes rainbowFlow {
    0% { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  /* Features */
  .features-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
  }

  .features-header { text-align: center; margin-bottom: 3rem; }
  .section-tag {
    display: inline-block;
    padding: 0.3rem 0.9rem;
    border-radius: 8px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--light-red);
    color: var(--dark-red);
    margin-bottom: 0.5rem;
  }
  .features-header h2 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0.3rem 0 0;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
    align-items: center;
  }
  .feature-row.reverse { direction: rtl; }
  .feature-row.reverse > * { direction: ltr; }

  .feature-bar {
    width: 40px;
    height: 4px;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }
  .bar-red { background: var(--red); }
  .bar-yellow { background: var(--yellow); }
  .bar-green { background: var(--green); }
  .bar-blue { background: var(--blue); }

  .feature-text h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
  }

  .feature-text p {
    font-size: 1rem;
    line-height: 1.8;
    color: #555;
    margin: 0;
  }

  .feature-img-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 28px rgba(0,0,0,0.08);
    transition: all 0.3s;
  }
  .feature-img-wrap:hover { box-shadow: 0 12px 40px rgba(0,0,0,0.12); transform: translateY(-2px); }
  .feature-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }
  .feature-glow {
    position: absolute;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0;
    top: -30px;
    right: -30px;
    transition: opacity 0.3s;
  }
  .feature-img-wrap:hover .feature-glow { opacity: 0.15; }
  .glow-red { background: var(--red); }
  .glow-yellow { background: var(--yellow); }
  .glow-green { background: var(--green); }
  .glow-blue { background: var(--blue); }

  /* CTA Section */
  .cta-section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--red), var(--dark-red));
    color: white;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .cta-block {
    position: absolute;
    border-radius: 40px;
    opacity: 0.08;
    animation: blockFloat 16s ease-in-out infinite;
  }
  .cta-block-1 { width: 40%; height: 60%; background: white; top: -20%; right: -10%; animation-duration: 14s; }
  .cta-block-2 { width: 30%; height: 45%; background: var(--yellow); bottom: -15%; left: -8%; animation-delay: -4s; animation-direction: reverse; }

  .cta-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    opacity: 0.3;
    pointer-events: none;
  }

  .cta-inner { max-width: 700px; margin: 0 auto; position: relative; z-index: 1; }
  .cta-inner h2 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 1rem;
  }
  .cta-inner > p {
    font-size: 1.1rem;
    line-height: 1.8;
    margin: 0 0 1.5rem;
    opacity: 0.95;
  }

  .cta-section .warning-bubble {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.25);
  }
  .cta-section .warning-bubble p { color: rgba(255,255,255,0.95); }

  .cta-btn {
    display: inline-block;
    padding: 1rem 3rem;
    background: white;
    color: var(--red);
    border-radius: 14px;
    font-weight: 700;
    font-size: 1.15rem;
    transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.2);
  }

  /* Links bar */
  .links-bar {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 1.5rem;
    background: rgba(0,0,0,0.02);
  }
  .links-bar a {
    color: #888;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .links-bar a:hover { color: var(--red); }

  /* Responsive */
  @media (max-width: 768px) {
    .hero { padding: 5rem 1.5rem 3rem; }
    .hero-content { grid-template-columns: 1fr; text-align: center; }
    .hero-text { align-items: center; }
    .hero-media { order: -1; }
    .hero-cta { align-self: center; }
    .warning-bubble { margin-left: auto; margin-right: auto; }
    .feature-row, .feature-row.reverse { grid-template-columns: 1fr; direction: ltr; }
    .features-header h2 { font-size: 1.6rem; }
    .feature-text h3 { font-size: 1.3rem; }
    .cta-inner h2 { font-size: 1.6rem; }
  }
</style>
