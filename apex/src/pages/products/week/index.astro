---
import PageLayout from '../../../layouts/PageLayout.astro';

const pageTitle = 'Week - 個人向けの時間割表';
const pageDescription = '社会人も学生みたいに時間割表が欲しい！生活リズムを整えるために使うシンプルな時間割表アプリです。ログイン不要ですぐに使えて、作成した時間割は画像として保存できます。';
const appUrl = 'https://week.rubydog.jp';
const ogImageUrl = 'https://rubydog.jp/products/week/pr-main-image.png';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Week',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Web Browser',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
  description: pageDescription,
  url: appUrl,
  screenshot: ogImageUrl,
  author: { '@type': 'Person', name: 'ルビーDog' }
};

const features = [
  {
    title: '気軽に！簡単に！',
    desc: 'ログイン不要ですぐに使えます。データを保存したい場合は、Googleアカウントでログインすることも可能です。思い立ったその瞬間から、あなたの時間割作成を始められます。',
    img: '/products/week/pr-sub1.png',
    alt: 'ログイン不要ですぐに使えるWeekの画面',
  },
  {
    title: '生活リズムを整える！',
    desc: '特に睡眠時間の習慣化は重要です。その他習慣化したいスケジュールだけ入力しておくのもおすすめです。規則正しい生活で、より良い毎日を送りましょう。',
    img: '/products/week/pr-sub2.png',
    alt: '生活リズムを整えるための時間割設定画面',
  },
  {
    title: '便利に！',
    desc: '作成した時間割は画像として保存できます。目的を問わず利用可能です。スマホの壁紙にしたり、SNSでシェアしたり、自由に活用できます。',
    img: '/products/week/pr-sub3.png',
    alt: '時間割を画像として保存する機能',
  },
  {
    title: '自由に！',
    desc: '旅行やイベントの日程共有にも使えます。好きなように使ってください。アイデア次第で、時間割表の可能性は無限大です。',
    img: '/products/week/pr-sub4.png',
    alt: '旅行やイベントにも使える柔軟な時間割',
  }
];
---

<PageLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content="https://rubydog.jp/products/week" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Rubydog JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="keywords" content="時間割表,タイムテーブル,生活リズム,習慣化,スケジュール管理,無料アプリ,ログイン不要" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <div class="week-page">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg-1"></div>
      <div class="hero-bg-2"></div>
      <div class="hero-content">
        <div class="hero-text" data-aos="fade-right" data-aos-duration="800">
          <div class="hero-title-row">
            <img src="/products/week/app-icon.png" alt="Week アイコン" class="app-icon" />
            <h1>Week</h1>
          </div>
          <p class="hero-subtitle">個人向けの時間割表</p>
          <p class="hero-desc">
            社会人も学生みたいに時間割表が欲しい！<br />
            生活リズムを整えるために使うシンプルな時間割表アプリです。
          </p>
          <div class="warning-bubble">
            <p>【Xから来てくれた人へ】<br/>アプリがうまく読み込めない場合は、右上のメニューから<strong>再読み込み</strong>するか、<strong>別のブラウザで開いて</strong>ください。</p>
          </div>
          <a href={appUrl} target="_blank" rel="noopener noreferrer" class="hero-cta" data-magnetic>
            アプリを開く
          </a>
        </div>
        <div class="hero-media" data-aos="fade-left" data-aos-duration="800" data-aos-delay="200">
          <video autoplay loop muted playsinline poster="/products/week/pr-main-image.png" aria-label="Weekアプリのデモ動画">
            <source src="/products/week/pr-main-video.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <h2 class="features-title" data-aos="fade-up">主な機能</h2>
      {features.map((f, i) => (
        <article class:list={['feature-row', { reverse: i % 2 === 1 }]} data-aos="fade-up" data-aos-delay={i * 80}>
          <div class="feature-text">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
          <div class="feature-img">
            <img src={f.img} alt={f.alt} loading="lazy" width="1920" height="1080" />
          </div>
        </article>
      ))}
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="cta-inner" data-aos="fade-up">
        <h2>今すぐ始めましょう</h2>
        <p>登録不要で使える、完全無料のアプリ。データを保存したい場合はログインも可能です。</p>
        <div class="warning-bubble cta-warning">
          <p>【Xからお越しの方へ】<br/>正常に読み込めない場合は、右上のメニューから<strong>再読み込み</strong>するか、<strong>別のブラウザで開いて</strong>ください。</p>
        </div>
        <a href={appUrl} target="_blank" rel="noopener noreferrer" class="cta-btn" data-magnetic>
          アプリを開く
        </a>
      </div>
    </section>

    <!-- Links -->
    <nav class="links-bar" aria-label="関連リンク">
      <a href="/apps/privacy">プライバシーポリシー</a>
      <a href="/apps/terms">利用規約</a>
    </nav>
  </div>
</PageLayout>

<style>
  .week-page { width: 100%; }

  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
  }

  .hero-bg-1, .hero-bg-2 {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.12;
    pointer-events: none;
  }
  .hero-bg-1 { width: 500px; height: 500px; background: var(--red); top: -100px; right: -100px; }
  .hero-bg-2 { width: 400px; height: 400px; background: var(--yellow); bottom: -80px; left: -80px; }

  .hero-content {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-text { display: flex; flex-direction: column; gap: 1rem; }

  .hero-title-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .app-icon {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    background: white;
    padding: 6px;
    box-sizing: border-box;
  }

  .hero-title-row h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #1a1a1a;
    margin: 0;
  }

  .hero-subtitle {
    font-size: 1.3rem;
    color: var(--red);
    font-weight: 600;
    margin: 0;
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #555;
    margin: 0;
  }

  .hero-cta {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: var(--red);
    color: white;
    border-radius: 14px;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(234,64,54,0.2);
    align-self: flex-start;
  }
  .hero-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(234,64,54,0.3);
  }

  .hero-media video {
    width: 100%;
    max-width: 480px;
    border-radius: 20px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.12);
    display: block;
    margin: 0 auto;
  }

  /* Warning Bubble */
  .warning-bubble {
    background: rgba(255,186,0,0.1);
    border: 1px solid rgba(255,186,0,0.3);
    border-radius: 12px;
    padding: 0.8rem 1.2rem;
    max-width: 460px;
  }
  .warning-bubble p {
    margin: 0;
    color: #775a00;
    font-size: 0.88rem;
    line-height: 1.6;
    font-weight: 500;
  }
  .warning-bubble p strong { font-weight: 700; }
  .cta-warning { margin: 0 auto 1.5rem; }

  /* Features */
  .features {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
  }

  .features-title {
    font-size: 2rem;
    font-weight: 800;
    text-align: center;
    color: #1a1a1a;
    margin: 0 0 3rem;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
    align-items: center;
  }
  .feature-row.reverse { direction: rtl; }
  .feature-row.reverse > * { direction: ltr; }

  .feature-text h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--red);
    margin: 0 0 0.75rem;
  }

  .feature-text p {
    font-size: 1rem;
    line-height: 1.8;
    color: #555;
    margin: 0;
  }

  .feature-img {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 28px rgba(0,0,0,0.08);
  }
  .feature-img img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, var(--red), var(--dark-red));
    color: white;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .cta-inner { max-width: 700px; margin: 0 auto; }
  .cta-inner h2 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 1rem;
  }
  .cta-inner > p {
    font-size: 1.1rem;
    line-height: 1.8;
    margin: 0 0 1.5rem;
    opacity: 0.95;
  }

  .cta-section .warning-bubble {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.25);
  }
  .cta-section .warning-bubble p { color: rgba(255,255,255,0.95); }

  .cta-btn {
    display: inline-block;
    padding: 1rem 3rem;
    background: white;
    color: var(--red);
    border-radius: 14px;
    font-weight: 700;
    font-size: 1.15rem;
    transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.2);
  }

  /* Links bar */
  .links-bar {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 1.5rem;
    background: rgba(0,0,0,0.02);
  }
  .links-bar a {
    color: #888;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .links-bar a:hover { color: var(--red); }

  /* Responsive */
  @media (max-width: 768px) {
    .hero { padding: 5rem 1.5rem 3rem; }
    .hero-content { grid-template-columns: 1fr; text-align: center; }
    .hero-text { align-items: center; }
    .hero-media { order: -1; }
    .hero-cta { align-self: center; }
    .warning-bubble { margin-left: auto; margin-right: auto; }
    .feature-row, .feature-row.reverse { grid-template-columns: 1fr; direction: ltr; }
    .features-title { font-size: 1.6rem; }
    .feature-text h3 { font-size: 1.3rem; }
    .cta-inner h2 { font-size: 1.6rem; }
  }
</style>
