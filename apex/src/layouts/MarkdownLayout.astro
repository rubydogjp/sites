---
import PageLayout from './PageLayout.astro';

const { frontmatter } = Astro.props;
---

<PageLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="markdown-content" data-aos="fade-up">
    <slot />
  </article>
</PageLayout>

<style>
  .markdown-content {
    max-width: 750px;
    margin: 0 auto;
    padding: 7rem 1.5rem 4rem;
    line-height: 1.8;
    color: #444;
  }

  .markdown-content :global(h1) {
    font-size: 2rem;
    font-weight: 800;
    margin: 2rem 0 1rem;
    color: #1a1a1a;
  }

  .markdown-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    color: #1a1a1a;
  }

  .markdown-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: #333;
  }

  .markdown-content :global(p) { margin-bottom: 1rem; }

  .markdown-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5rem auto;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  .markdown-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .markdown-content :global(th),
  .markdown-content :global(td) {
    border: 1px solid rgba(0,0,0,0.06);
    padding: 0.75rem;
    text-align: left;
  }

  .markdown-content :global(th) {
    background: rgba(0,0,0,0.02);
    font-weight: 600;
  }

  .markdown-content :global(ul),
  .markdown-content :global(ol) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .markdown-content :global(li) { margin-bottom: 0.4rem; }

  .markdown-content :global(a:not(.linkbutton)) {
    color: var(--blue);
    font-weight: 500;
  }

  .markdown-content :global(a:not(.linkbutton):hover) {
    text-decoration: underline;
  }

  .markdown-content :global(a.linkbutton) {
    display: inline-block;
    padding: 0.7rem 1.8rem;
    font-weight: 600;
    border-radius: 12px;
    background: var(--blue);
    color: #fff !important;
    border: none;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(37,132,252,0.2);
    font-size: 0.95rem;
  }

  .markdown-content :global(a.linkbutton:hover) {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37,132,252,0.3);
    text-decoration: none;
    color: #fff !important;
  }

  .markdown-content :global(hr) {
    margin: 2rem 0;
    border: none;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .markdown-content :global(.tip) {
    background: rgba(208,231,255,0.3);
    border-left: 4px solid var(--blue);
    padding: 1rem 1.5rem;
    margin: 1rem 0;
    border-radius: 0 12px 12px 0;
  }
</style>
