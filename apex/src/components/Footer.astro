---
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const recentNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

type FooterLink = {
  label: string;
  href: string;
  external?: boolean;
};

type FooterSection = {
  title: string;
  items: FooterLink[];
};

const footerLinks: FooterSection[] = [
  {
    title: '製品',
    items: [
      { label: 'アプリ', href: '/apps' },
      { label: '講座', href: '/notes' },
      { label: 'ライブラリ', href: '/packages' }
    ]
  },
  {
    title: 'サポート',
    items: [
      { label: 'お問い合わせ', href: '/contact' },
      { label: 'プライバシーポリシー', href: '/apps/privacy' },
      { label: '利用規約', href: '/apps/terms' }
    ]
  },
  {
    title: '外部リンク',
    items: [
      { label: 'GitHub', href: 'https://github.com/rubydogjp', external: true },
      { label: 'Youtube', href: 'https://www.youtube.com/@rbdog', external: true },
      { label: 'X', href: 'https://x.com/rubydog_jp', external: true }
    ]
  }
];
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-links">
        {footerLinks.map(section => (
          <div class="footer-section">
            <h4 class="footer-title">{section.title}</h4>
            <ul class="footer-list">
              {section.items.map(item => (
                <li>
                  <a
                    href={item.href}
                    class="footer-link"
                    target={item.external ? '_blank' : undefined}
                    rel={item.external ? 'noopener noreferrer' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <div class="footer-section">
          <h4 class="footer-title">ニュース</h4>
          <ul class="footer-list">
            {recentNews.map(news => (
              <li>
                <a href={`/news/${news.slug}`} class="footer-link">
                  <span class="footer-news-date">
                    {news.data.date.toLocaleDateString('ja-JP', { month: 'short', day: 'numeric' })}
                  </span>
                  {news.data.title}
                </a>
              </li>
            ))}
            <li>
              <a href="/news" class="footer-link footer-link-more">すべてのニュース</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-copyright">
      Copyright &copy; 2023 Rubydog JP
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #242526;
    color: rgba(255, 255, 255, 0.6);
    padding: 3rem 0 1.5rem;
  }

  .footer-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .footer-main {
    margin-bottom: 2rem;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .footer-section {
    display: flex;
    flex-direction: column;
  }

  .footer-title {
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-list li {
    margin-bottom: 0.5rem;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .footer-link:hover {
    color: #fff;
  }

  .footer-news-date {
    display: inline-block;
    font-size: 0.8rem;
    opacity: 0.7;
    margin-right: 0.5rem;
  }

  .footer-link-more {
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
  }

  .footer-copyright {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.9rem;
  }
</style>
