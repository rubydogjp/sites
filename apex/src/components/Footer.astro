---
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const recentNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

type FooterLink = { label: string; href: string; external?: boolean; };
type FooterSection = { title: string; items: FooterLink[]; };

const footerLinks: FooterSection[] = [
  {
    title: '製品',
    items: [
      { label: 'アプリ', href: '/apps' },
      { label: '講座', href: '/notes' },
      { label: 'ライブラリ', href: '/packages' },
    ]
  },
  {
    title: 'サポート',
    items: [
      { label: 'お問い合わせ', href: '/contact' },
      { label: 'プライバシーポリシー', href: '/apps/privacy' },
      { label: '利用規約', href: '/apps/terms' },
    ]
  },
  {
    title: '外部リンク',
    items: [
      { label: 'GitHub', href: 'https://github.com/rubydogjp', external: true },
      { label: 'YouTube', href: 'https://www.youtube.com/@rbdog', external: true },
      { label: 'X', href: 'https://x.com/rubydogjp', external: true },
    ]
  }
];
---

<footer class="footer">
  <div class="footer-rainbow"></div>
  <div class="footer-container">
    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="brand-link">
        <img src="/img/profile.png" alt="Rubydog JP" class="footer-logo" />
        <span>Rubydog JP</span>
      </a>
      <p class="brand-desc">ソフトウェア技術をもっと分かりやすく</p>
    </div>

    <!-- Links -->
    <div class="footer-links">
      {footerLinks.map(section => (
        <div class="footer-section">
          <h4>{section.title}</h4>
          <ul>
            {section.items.map(item => (
              <li>
                <a
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener noreferrer' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="footer-section">
        <h4>ニュース</h4>
        <ul>
          {recentNews.map(news => (
            <li>
              <a href={`/news/${news.slug}`}>
                <span class="news-date">
                  {news.data.date.toLocaleDateString('ja-JP', { month: 'short', day: 'numeric' })}
                </span>
                {news.data.title}
              </a>
            </li>
          ))}
          <li><a href="/news" class="more">すべてのニュース</a></li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="footer-copyright">
      Copyright &copy; 2023 Rubydog JP
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1a1a1a;
    color: rgba(255,255,255,0.5);
    position: relative;
  }

  .footer-rainbow {
    height: 3px;
    background: linear-gradient(90deg, var(--red), var(--yellow), var(--green), var(--blue));
  }

  .footer-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 1.5rem;
  }

  /* Brand */
  .footer-brand { margin-bottom: 2rem; }
  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
  }
  .footer-logo { width: 28px; height: 28px; border-radius: 8px; }
  .brand-desc { font-size: 0.8rem; margin-top: 0.4rem; color: rgba(255,255,255,0.35); }

  /* Links */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-section h4 {
    color: rgba(255,255,255,0.8);
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .footer-section ul { list-style: none; padding: 0; margin: 0; }
  .footer-section li { margin-bottom: 0.4rem; }

  .footer-section a {
    color: rgba(255,255,255,0.45);
    font-size: 0.82rem;
    transition: color 0.2s;
    line-height: 1.5;
  }
  .footer-section a:hover { color: white; }

  .news-date { display: inline-block; font-size: 0.75rem; opacity: 0.6; margin-right: 0.3rem; }
  .more { font-weight: 500; color: rgba(255,255,255,0.6) !important; }

  /* Copyright */
  .footer-copyright {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    font-size: 0.8rem;
  }
</style>
