{
  "workbench.colorCustomizations": {
    // タイトルバー — 白背景に黒文字
    "titleBar.activeBackground": "#FFFFFF",
    "titleBar.activeForeground": "#333333",
    "titleBar.inactiveBackground": "#F5F5F5",
    "titleBar.inactiveForeground": "#33333380",

    // ステータスバー — 白背景に黒文字
    "statusBar.background": "#FFFFFF",
    "statusBar.foreground": "#333333",
    "statusBar.debuggingBackground": "#EA4036",
    "statusBar.debuggingForeground": "#FFFFFF",
    "statusBar.noFolderBackground": "#888888",
    "statusBarItem.hoverBackground": "#FFD6D3",
    "statusBarItem.remoteBackground": "#EA4036",
    "statusBarItem.remoteForeground": "#FFFFFF",

    // アクティビティバー — 赤に白文字
    "activityBar.background": "#EA4036",
    "activityBar.foreground": "#FFFFFF",
    "activityBar.inactiveForeground": "#FFFFFF80",
    "activityBar.activeBackground": "#FFFFFF22",
    "activityBar.activeBorder": "#FFFFFF",
    "activityBarBadge.background": "#FFFFFF",
    "activityBarBadge.foreground": "#C5221F"
  },

  "window.title": "Rubydog Sites",

  "files.exclude": {
    "node_modules": true,
    "package-lock.json": true,
    "babel.config.js": true,
    ".docusaurus": true,
    ".gitignore": true,
    ".nojekyll": true,
    "sitemap.xml": true,
    "markdown-page": true,
    "assets": true,
    "404.html": true
  },
  // JS
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "cSpell.words": ["hunny", "rbdog", "Rubydog"]
}
