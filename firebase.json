{
  "hosting": [
    {
      "target": "apex",
      "public": "apex/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/packages/**", "destination": "/packages/index.html" },
        { "source": "/hunny/viewer/**", "destination": "/hunny/viewer/index.html" },
        { "source": "/notes/**", "destination": "/notes/index.html" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "hunny",
      "public": "hunny/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "/viewer/**", "destination": "/viewer/index.html" }]
    },
    {
      "target": "flutter-note",
      "public": "_build/flutter-note",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    }
  ]
}
